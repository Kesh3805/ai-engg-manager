# ─── Core infra ──────────────────────────────────────────────────────────────
# Port 55432 = pgvector Docker container (avoids native Postgres on 5432/5433)
DATABASE_URL=postgresql://aiem:aiem@localhost:55432/aiem
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200

# ─── Event streaming (Confluent Cloud / Aiven, mTLS) ─────────────────────────
CONFLUENT_BOOTSTRAP=
KAFKA_CA_PATH=ca.pem
KAFKA_CERT_PATH=service.cert
KAFKA_KEY_PATH=service.key
# (SASL alternative — leave blank when using mTLS certs above)
CONFLUENT_API_KEY=
CONFLUENT_API_SECRET=

# ─── Auth ────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-a-32+-char-random-secret-string
# Require GitHub sign-in before /app/* (default open for local dev)
AUTH_ENFORCE=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ─── LLM providers (OpenAI-compatible; NVIDIA NIM here) ──────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
LLM_MODEL=meta/llama-3.3-70b-instruct
EMBED_MODEL=baai/bge-m3
EMBED_DIM=1024

# ─── Object storage ──────────────────────────────────────────────────────────
S3_BUCKET=ai-eng-manager
S3_ENDPOINT=http://localhost:9000

# ─── AST identity ────────────────────────────────────────────────────────────
# Stable UUIDv5 namespace — generate once with `node -e "console.log(crypto.randomUUID())"`
AST_UUID_NAMESPACE=6ba7b810-9dad-11d1-80b4-00c04fd430c8

# ─── Client ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DATABASE_URL is required — the web app runs live only and throws on boot without
# it. There is no mock fallback; surfaces with no data yet render empty states.
